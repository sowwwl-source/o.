# Production env example (copy to .env on the server)
DB_HOST=db
DB_PORT=3306
DB_NAME=sowwwl
DB_USER=sowwwl
DB_PASS=CHANGE_THIS_PASSWORD

MYSQL_ROOT_PASSWORD=CHANGE_THIS_ROOT_PASSWORD

# Optional: override the API image pulled by docker compose
API_IMAGE=ghcr.io/sowwwl-source/o-api:latest

# Optional: comma/space-separated emails allowed to perform network-admin actions (e.g. POST /qu3st)
# Example:
# O_NETWORK_ADMINS=abyssal.sowwwl@gmail.com
O_NETWORK_ADMINS=

# Optional: admin magic-link (email) settings
# - Send endpoint: POST /api/auth/admin/magic/send { email }
# - Verify (recommended): UI link /#/admin/magic/verify?token=... → POST /api/auth/admin/magic/verify {token}
# - Verify (legacy):      GET /api/auth/admin/magic/verify?token=... (302 → O_ADMIN_MAGIC_REDIRECT)
# O_ADMIN_MAGIC_TTL_MIN=15
# O_ADMIN_MAGIC_MAIL_MODE=smtp  # "smtp" (recommended), "mail" (requires local MTA), or "outbox" (dev)
# O_ADMIN_MAGIC_OUTBOX_DIR=/data/magic_outbox
# O_ADMIN_MAGIC_PUBLIC_HOST=0.user.o.sowwwl.cloud
# O_ADMIN_MAGIC_REDIRECT=/#/admin/b0ard
# O_EMAIL_HASH_SALT=CHANGE_THIS_RANDOM
#
# SMTP mode (recommended for Docker deploys)
# O_ADMIN_MAGIC_SMTP_HOST=ssl0.ovh.net
# O_ADMIN_MAGIC_SMTP_PORT=587
# O_ADMIN_MAGIC_SMTP_SECURE=starttls   # starttls | tls | none
# O_ADMIN_MAGIC_SMTP_USER=your-smtp-user
# O_ADMIN_MAGIC_SMTP_PASS=your-smtp-pass
# O_ADMIN_MAGIC_SMTP_FROM=no-reply@sowwwl.com
# O_ADMIN_MAGIC_SMTP_TIMEOUT_SEC=8
