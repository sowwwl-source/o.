# Caddyfile for sowwwl (front + API)
# Place in /etc/caddy/Caddyfile on production server.

# O. / Uzyx (global UI) — deployed to /var/www/o by GitHub Actions:
# - `.github/workflows/deploy-uzyx.yml` rsyncs `uzyx-app/dist/` → `/var/www/o/`
# - `/var/www/o/signals` is reserved for server-side drops (do not delete)
#
# Domain target (acté): `0.user.o.sowwwl.cloud`
0.user.o.sowwwl.cloud {
    root * /var/www/o

    # Optional: same-origin API proxy (strips /api)
    handle_path /api/* {
        reverse_proxy 127.0.0.1:8000
    }

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Referrer-Policy "no-referrer"
    }

    file_server
}

# Canonical public homepage (flowers / 0isO / soul.cloud)
sowwwl.cloud, www.sowwwl.cloud {
    root * /var/www/sowwwl-front

    handle_path /api/* {
        reverse_proxy 127.0.0.1:8000
    }

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Referrer-Policy "no-referrer"
    }

    file_server
}

# Optional legacy redirect
sowwwl.com, www.sowwwl.com {
    redir https://sowwwl.cloud{uri} 308
}

# Optional: direct API domain
api.sowwwl.com {
    reverse_proxy 127.0.0.1:8000

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Referrer-Policy "no-referrer"
    }

    log {
        output file /var/log/caddy/api.log
        format json
    }
}
